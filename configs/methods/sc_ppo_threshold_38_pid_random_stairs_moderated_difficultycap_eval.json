    "moderation_strategy": "retain the mixed rough/stairs composition from the first repair and cap stair difficulty at 0.5 through a local Humanoid-Gym terrain patch",
    "local_patch_dependency": "scripts/baseline/patch_humanoid_gym_stair_difficulty_env.py",
    "checkpoint_policy": "selected rough-terrain checkpoint only",
